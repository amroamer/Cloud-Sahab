<?xml version="1.0" encoding="utf-8"?>
  <configuration>
    <system.webServer>
      <handlers>
        <add
          name="iisnode"
          path="dist/index.cjs"
          verb="*"
          modules="iisnode" />
      </handlers>
      <rewrite>
        <rules>
          <!-- Route all requests to the Node.js app -->
          <rule name="NodeJS" stopProcessing="true">
            <match url=".*" />
            <action type="Rewrite" url="dist/index.cjs" />
          </rule>
        </rules>
      </rewrite>
      <security>
        <requestFiltering>
          <hiddenSegments>
            <!-- Prevent direct access to source files -->
            <add segment="node_modules" />
            <add segment="dist" />
          </hiddenSegments>
        </requestFiltering>
      </security>
    </system.webServer>
  </configuration>
